# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Copy this file to .env and fill your real credentials
DB_HOST=dbs-group6.database.windows.net
DB_PORT=1433
DB_NAME=dbs_baomatcsdl
DB_USER=<your_sql_username>
DB_PASSWORD=<your_sql_password>
DB_TYPE=mssql

# Azure SQL requires encryption
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

# Timeout (increase for Azure)
DB_CONNECTION_TIMEOUT=30000
DB_REQUEST_TIMEOUT=30000

# JWT Configuration
JWT_SECRET=super_secret_key_very_long_2026_security_project
JWT_EXPIRES_IN=24h
